     SCRIPTS
════════════════════════════════════════════════ -->
<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); observer.unobserve(e.target); } }),
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll<HTMLElement>('.reveal').forEach(el => observer.observe(el));

  function setLang(lang: string) {
    const html = document.documentElement;
    html.classList.remove('is-fr', 'is-th');
    if (lang === 'fr' || lang === 'th') html.classList.add(`is-${lang}`);
    html.setAttribute('lang', lang);
    document.querySelectorAll<HTMLElement>('.lang-btn').forEach(btn => {
      btn.classList.toggle('is-active', (btn as HTMLButtonElement & {dataset: {lang: string}}).dataset.lang === lang);
    });
    localStorage.setItem('lang', lang);
  }
  setLang(localStorage.getItem('lang') || 'en');
  document.querySelectorAll<HTMLButtonElement>('.lang-btn').forEach(btn => {
    btn.addEventListener('click', () => setLang(btn.dataset.lang ?? 'en'));
  });

  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('menu-open');
    toggle.classList.toggle('menu-is-open', isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });
  menu?.querySelectorAll<HTMLAnchorElement>('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.remove('menu-open');
      toggle?.classList.remove('menu-is-open');
      document.body.style.overflow = '';
    });
  });
</script>

