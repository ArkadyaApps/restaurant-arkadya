---
import BaseLayout from '../layouts/BaseLayout.astro';

const whatsappBase         = "https://wa.me/66886875964";
const lineUrl              = "https://line.me/ti/p/mLPxAMJQ95";
const whatsappGeneral      = `${whatsappBase}?text=Hello%2C+I%27m+interested+in+a+restaurant+website+with+Resto+by+Arkadya.`;
const whatsappPackage      = `${whatsappBase}?text=Hello%2C+I%27d+like+the+3%2C900+THB+restaurant+website.`;
const whatsappAudit        = `${whatsappBase}?text=Hello%2C+I%27d+like+a+free+audit+of+my+restaurant%27s+digital+presence.`;

const features = [
  {
    icon: `<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M9 14l2 2 4-4"/>`,
    color: "amber", stroke: "#D4884A", span: "md:col-span-5",
    en: { title: "Table Booking",         desc: "Guests reserve directly from your site. Every booking confirmed automatically via WhatsApp — no app to install." },
    fr: { title: "Réservation de tables", desc: "Vos clients réservent directement depuis votre site. Chaque réservation est confirmée automatiquement via WhatsApp." },
    th: { title: "จองโต๊ะออนไลน์",         desc: "แขกจองจากเว็บไซต์ของคุณโดยตรง ทุกการจองได้รับการยืนยันอัตโนมัติผ่าน WhatsApp" },
  },
  {
    icon: `<path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/>`,
    color: "orange", stroke: "#E8A060", span: "md:col-span-7",
    en: { title: "Digital Menu",           desc: "Beautiful photo menu or written items — in English, French, and Thai. Update it anytime without touching any code." },
    fr: { title: "Menu numérique",         desc: "Menu photo ou texte en anglais, français et thaï. Mettez-le à jour à tout moment, sans toucher au code." },
    th: { title: "เมนูดิจิทัล",              desc: "เมนูรูปภาพหรือรายการตัวอักษร ทั้งภาษาอังกฤษ ฝรั่งเศส และไทย อัปเดตได้ตลอดเวลาโดยไม่ต้องแตะโค้ด" },
  },
  {
    icon: `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>`,
    color: "amber", stroke: "#D4884A", span: "md:col-span-7",
    en: { title: "Google Maps & SEO",      desc: "Your restaurant appears when guests search nearby. Structured data and local SEO built in from day one." },
    fr: { title: "Google Maps & SEO",      desc: "Votre restaurant apparaît quand les clients cherchent dans votre quartier. SEO local et données structurées inclus." },
    th: { title: "Google Maps & SEO",      desc: "ร้านของคุณปรากฏเมื่อแขกค้นหาในพื้นที่ SEO ท้องถิ่นและ structured data รวมอยู่ตั้งแต่วันแรก" },
  },
  {
    icon: `<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/>`,
    color: "orange", stroke: "#E8A060", span: "md:col-span-5",
    en: { title: "More Visibility",        desc: "Customers find you on Google, browse your menu, and book directly — without any delivery platform in the way." },
    fr: { title: "Plus de visibilité",     desc: "Les clients vous trouvent sur Google, parcourent votre menu et réservent directement — sans intermédiaire." },
    th: { title: "เพิ่มการมองเห็น",         desc: "ลูกค้าค้นพบคุณบน Google ดูเมนู และจองตรงโดยไม่มีแพลตฟอร์มอื่นมาขวางกลาง" },
  },
  {
    icon: `<rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>`,
    color: "amber", stroke: "#D4884A", span: "md:col-span-6",
    en: { title: "Mobile-First Design",    desc: "80% of your guests will discover you on a phone. Every page is built to look perfect on any screen size." },
    fr: { title: "Design mobile-first",    desc: "80% de vos clients vous découvriront sur un téléphone. Chaque page est optimisée pour tous les écrans." },
    th: { title: "ออกแบบ Mobile-First",    desc: "80% ของแขกค้นพบคุณบนมือถือ ทุกหน้าสร้างให้สมบูรณ์แบบบนทุกขนาดหน้าจอ" },
  },
  {
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
    color: "orange", stroke: "#E8A060", span: "md:col-span-6",
    en: { title: "Live in 2 Days",          desc: "Send us your menu, hours, and photos. We design, build, and launch your restaurant website in just 2 days." },
    fr: { title: "En ligne en 2 jours",    desc: "Envoyez-nous votre menu, vos horaires et vos photos. Nous concevons et lançons votre site en seulement 2 jours." },
    th: { title: "เปิดตัวใน 2 วัน",          desc: "ส่งเมนู เวลาเปิด-ปิด และรูปถ่ายให้เรา เราออกแบบ สร้าง และเปิดตัวเว็บไซต์ร้านอาหารภายใน 2 วัน" },
  },
];

const steps = [
  {
    n: "01",
    en: { title: "Send Us Your Content",    desc: "Share your menu, opening hours, address, and a few photos. That's all we need to start building." },
    fr: { title: "Envoyez-nous votre contenu", desc: "Partagez votre menu, vos horaires, votre adresse et quelques photos. C'est tout ce qu'il nous faut pour commencer." },
    th: { title: "ส่งเนื้อหาให้เรา",           desc: "แชร์เมนู เวลาทำการ ที่อยู่ และรูปถ่ายไม่กี่รูป นั่นคือทั้งหมดที่เราต้องการเพื่อเริ่มสร้าง" },
  },
  {
    n: "02",
    en: { title: "We Build & Launch",       desc: "Your multilingual website goes live in 2 days — with booking, menu, maps, and WhatsApp fully wired." },
    fr: { title: "Nous construisons & lançons", desc: "Votre site multilingue est en ligne en 2 jours — avec réservations, menu, maps et WhatsApp configurés." },
    th: { title: "เราสร้างและเปิดตัว",          desc: "เว็บไซต์หลายภาษาของคุณเปิดตัวใน 2 วัน พร้อมการจอง เมนู แผนที่ และ WhatsApp ครบ" },
  },
  {
    n: "03",
    en: { title: "We Keep It Updated",      desc: "Need to change prices, add a dish, or update hours? Message us on WhatsApp. We handle it the same day." },
    fr: { title: "Nous maintenons à jour",  desc: "Besoin de changer les prix, ajouter un plat ou modifier les horaires ? Envoyez-nous un message WhatsApp. Fait le jour même." },
    th: { title: "เราอัปเดตให้คุณ",           desc: "ต้องการเปลี่ยนราคา เพิ่มเมนู หรืออัปเดตเวลาทำการ? ส่งข้อความ WhatsApp ให้เรา เราจัดการให้ในวันเดียวกัน" },
  },
];

const packageFeatures = [
  { en: "Custom restaurant website",          fr: "Site web personnalisé pour votre restaurant",    th: "เว็บไซต์ร้านอาหารแบบกำหนดเอง" },
  { en: "EN / FR / TH multilingual",          fr: "Multilingue EN / FR / TH",                       th: "หลายภาษา EN / FR / TH" },
  { en: "Table booking with WhatsApp",         fr: "Réservation de tables + confirmation WhatsApp",  th: "จองโต๊ะพร้อมยืนยัน WhatsApp" },
  { en: "Digital menu (photos or items)",      fr: "Menu numérique (photos ou liste)",               th: "เมนูดิจิทัล (รูปภาพหรือรายการ)" },
  { en: "Google Maps & SEO — get found locally", fr: "Google Maps & SEO — visible localement",        th: "Google Maps & SEO — ให้ลูกค้าค้นพบคุณ" },
  { en: "Mobile-first responsive design",      fr: "Design responsive mobile-first",                 th: "การออกแบบ Mobile-first" },
  { en: "Launch in 2 days",                    fr: "Lancement en 2 jours",                           th: "เปิดตัวใน 2 วัน" },
  { en: "0% commission on direct bookings",    fr: "0% de commission sur les réservations directes", th: "0% ค่าคอมมิชชั่นสำหรับการจองโดยตรง" },
];
---

<BaseLayout>

<!-- ════════════════════════════════════════════════
     FLOATING NAV
════════════════════════════════════════════════ -->
<header class="fixed top-0 inset-x-0 z-50 flex justify-center pt-5 px-4">
  <nav class="w-full max-w-5xl flex items-center justify-between gap-4 px-5 py-2.5 rounded-full
              backdrop-blur-xl bg-black/35 border border-white/[0.08]
              shadow-[0_8px_40px_rgba(0,0,0,0.5)]">

    <a href="/" class="flex items-center gap-1 shrink-0 select-none">
      <span class="font-display text-cream text-[1.1rem] font-semibold tracking-tight leading-none">
        <span class="text-amber mr-px opacity-60">/</span>Resto by Arkadya
      </span>
    </a>

    <div class="hidden md:flex items-center gap-6">
      <a href="#features" class="text-cream-dim text-[0.8rem] font-medium hover:text-cream transition-colors duration-300">
        <span class="lang-en">Features</span><span class="lang-fr">Fonctionnalités</span><span class="lang-th">ฟีเจอร์</span>
      </a>
      <a href="#process" class="text-cream-dim text-[0.8rem] font-medium hover:text-cream transition-colors duration-300">
        <span class="lang-en">How It Works</span><span class="lang-fr">Comment ça marche</span><span class="lang-th">วิธีการทำงาน</span>
      </a>
      <a href="#pricing" class="text-cream-dim text-[0.8rem] font-medium hover:text-cream transition-colors duration-300">
        <span class="lang-en">Pricing</span><span class="lang-fr">Tarifs</span><span class="lang-th">ราคา</span>
      </a>
    </div>

    <div class="flex items-center gap-2">
      <div class="flex items-center gap-0.5 p-0.5 rounded-full border border-white/[0.08]">
        <button class="lang-btn px-2.5 py-1 rounded-full text-[10px] font-semibold tracking-wide" data-lang="en">EN</button>
        <button class="lang-btn px-2.5 py-1 rounded-full text-[10px] font-semibold tracking-wide" data-lang="fr">FR</button>
        <button class="lang-btn px-2.5 py-1 rounded-full text-[10px] font-semibold tracking-wide" data-lang="th">TH</button>
      </div>

      <a href={whatsappPackage}
         class="hidden md:flex items-center gap-2 px-4 py-2 rounded-full bg-amber text-ember
                text-[0.8rem] font-semibold group
                transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]
                hover:bg-amber-light active:scale-[0.97]">
        <span class="lang-en">Get Started</span><span class="lang-fr">Commencer</span><span class="lang-th">เริ่มต้น</span>
        <span class="w-5 h-5 rounded-full bg-black/10 flex items-center justify-center
                     group-hover:translate-x-0.5 group-hover:-translate-y-px
                     transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]">
          <svg width="8" height="8" viewBox="0 0 8 8" fill="none"><path d="M1.5 6.5L6.5 1.5M6.5 1.5H2.5M6.5 1.5V5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>

      <button id="menu-toggle" class="md:hidden relative w-9 h-9 flex flex-col items-center justify-center gap-[5px]" aria-label="Toggle navigation">
        <span id="ham-top" class="w-[18px] h-[1.5px] bg-cream rounded-full block origin-center"></span>
        <span id="ham-bot" class="w-[18px] h-[1.5px] bg-cream rounded-full block origin-center"></span>
      </button>
    </div>
  </nav>
</header>

<div id="mobile-menu" class="fixed inset-0 z-40 flex flex-col items-center justify-center gap-9 bg-ember/95 backdrop-blur-3xl">
  <a href="#features"  class="nav-link font-display text-[2.2rem] text-cream hover:text-amber transition-colors">
    <span class="lang-en">Features</span><span class="lang-fr">Fonctionnalités</span><span class="lang-th">ฟีเจอร์</span>
  </a>
  <a href="#process"   class="nav-link font-display text-[2.2rem] text-cream hover:text-amber transition-colors">
    <span class="lang-en">How It Works</span><span class="lang-fr">Comment ça marche</span><span class="lang-th">วิธีการทำงาน</span>
  </a>
  <a href="#pricing"   class="nav-link font-display text-[2.2rem] text-cream hover:text-amber transition-colors">
    <span class="lang-en">Pricing</span><span class="lang-fr">Tarifs</span><span class="lang-th">ราคา</span>
  </a>
  <a href={whatsappPackage} class="nav-link mt-2 px-8 py-4 rounded-full bg-amber text-ember font-semibold text-lg">
    <span class="lang-en">Get Started — 3,900 THB</span>
    <span class="lang-fr">Commencer — 3 900 THB</span>
    <span class="lang-th">เริ่มต้น — 3,900 บาท</span>
  </a>
</div>


<!-- ════════════════════════════════════════════════
     HERO
════════════════════════════════════════════════ -->
<section class="relative min-h-[100dvh] flex items-center pt-28 pb-20 px-4 overflow-hidden">

  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/3 left-1/4 w-[500px] h-[500px] rounded-full bg-amber/[0.04] blur-[130px]"></div>
    <div class="absolute bottom-1/4 right-1/3 w-[400px] h-[400px] rounded-full bg-orange-900/20 blur-[100px]"></div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto w-full space-y-8">

    <div class="reveal inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-amber/25 bg-amber/[0.07]">
      <span class="w-1.5 h-1.5 rounded-full bg-amber animate-pulse shrink-0"></span>
      <span class="text-amber text-[10.5px] uppercase tracking-[0.22em] font-semibold">
        <span class="lang-en">Restaurant Websites · Thailand</span>
        <span class="lang-fr">Sites web pour restaurants · Thaïlande</span>
        <span class="lang-th">เว็บไซต์ร้านอาหาร · ประเทศไทย</span>
      </span>
    </div>

    <div class="reveal reveal-d1">
      <h1 class="font-display leading-[1.05] font-semibold text-cream" style="font-size: clamp(2.8rem, 6.5vw, 5.5rem);">
        <span class="lang-en">Stop Losing Guests<br/><em class="text-amber-gradient not-italic">to Food Apps.</em></span>
        <span class="lang-fr">Arrêtez de perdre vos clients<br/><em class="text-amber-gradient not-italic">aux apps de livraison.</em></span>
        <span class="lang-th">หยุดสูญเสียแขก<br/><em class="text-amber-gradient not-italic">ให้กับแอปส่งอาหาร</em></span>
      </h1>
    </div>

    <p class="reveal reveal-d2 text-cream-dim text-[1.05rem] leading-relaxed max-w-[32rem]">
      <span class="lang-en">A beautiful multilingual restaurant website — with table booking, digital menu, and WhatsApp — launched in 2 days.</span>
      <span class="lang-fr">Un site web multilingue pour votre restaurant — avec réservation de tables, menu numérique et WhatsApp — lancé en 2 jours.</span>
      <span class="lang-th">เว็บไซต์ร้านอาหารหลายภาษาที่สวยงาม — พร้อมการจองโต๊ะ เมนูดิจิทัล และ WhatsApp — เปิดตัวใน 2 วัน</span>
    </p>

    <div class="reveal reveal-d3 flex flex-col sm:flex-row gap-3">
      <a href={whatsappGeneral}
         class="group flex items-center justify-center gap-2.5 px-6 py-3.5 rounded-full
                bg-amber text-ember font-semibold text-sm
                transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]
                hover:bg-amber-light active:scale-[0.97]
                shadow-[0_6px_28px_rgba(212,136,74,0.28)]">
        <span class="lang-en">Launch Your Restaurant Site</span>
        <span class="lang-fr">Lancer votre site restaurant</span>
        <span class="lang-th">เปิดตัวเว็บไซต์ร้านอาหาร</span>
        <span class="w-7 h-7 rounded-full bg-black/10 flex items-center justify-center
                     group-hover:translate-x-0.5 group-hover:-translate-y-0.5
                     transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 8L8 2M8 2H3M8 2V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>
      <a href="#features"
         class="flex items-center justify-center gap-2 px-6 py-3.5 rounded-full
                border border-white/10 text-cream text-sm font-medium
                hover:border-amber/30 hover:text-amber transition-all duration-300">
        <span class="lang-en">See All Features</span>
        <span class="lang-fr">Voir les fonctionnalités</span>
        <span class="lang-th">ดูฟีเจอร์ทั้งหมด</span>
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" class="opacity-50 mt-px"><path d="M6.5 1v11M1 6.5l5.5 5.5 5.5-5.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>


  </div>

  <div class="absolute bottom-7 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-35" aria-hidden="true">
    <span class="text-cream text-[9px] uppercase tracking-[0.3em]">Scroll</span>
    <div class="w-px h-9 bg-gradient-to-b from-cream to-transparent"></div>
  </div>
</section>


<!-- ════════════════════════════════════════════════
     STATS STRIP
════════════════════════════════════════════════ -->
<section class="py-12 border-y border-white/[0.05]">
  <div class="max-w-5xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-8">
    <div class="reveal text-center">
      <div class="font-display font-semibold text-cream" style="font-size: clamp(2.2rem, 3.5vw, 2.8rem);">2</div>
      <div class="text-cream-dim text-[0.78rem] mt-1">
        <span class="lang-en">Days to launch</span><span class="lang-fr">Jours pour le lancement</span><span class="lang-th">วันในการเปิดตัว</span>
      </div>
    </div>
    <div class="reveal reveal-d1 text-center">
      <div class="font-display font-semibold text-cream" style="font-size: clamp(2.2rem, 3.5vw, 2.8rem);">3</div>
      <div class="text-cream-dim text-[0.78rem] mt-1">
        <span class="lang-en">Languages: EN · FR · TH</span><span class="lang-fr">Langues : EN · FR · TH</span><span class="lang-th">ภาษา: EN · FR · TH</span>
      </div>
    </div>
    <div class="reveal reveal-d2 text-center">
      <div class="font-display font-semibold text-orange-400" style="font-size: clamp(2.2rem, 3.5vw, 2.8rem);">0%</div>
      <div class="text-cream-dim text-[0.78rem] mt-1">
        <span class="lang-en">Commission on bookings</span><span class="lang-fr">Commission sur réservations</span><span class="lang-th">ค่าคอมมิชชั่นการจอง</span>
      </div>
    </div>
    <div class="reveal reveal-d3 text-center">
      <div class="font-display font-semibold text-cream" style="font-size: clamp(2.2rem, 3.5vw, 2.8rem);">3,900</div>
      <div class="text-cream-dim text-[0.78rem] mt-1">
        <span class="lang-en">THB one-time</span><span class="lang-fr">THB paiement unique</span><span class="lang-th">บาท จ่ายครั้งเดียว</span>
      </div>
    </div>
  </div>
</section>


<!-- ════════════════════════════════════════════════
     FEATURES
════════════════════════════════════════════════ -->
<section id="features" class="py-36 px-4">
  <div class="max-w-6xl mx-auto">

    <div class="text-center mb-16 space-y-4">
      <div class="reveal inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-amber/25 bg-amber/[0.07]">
        <span class="text-amber text-[10.5px] uppercase tracking-[0.22em] font-semibold">
          <span class="lang-en">Everything you need</span><span class="lang-fr">Tout ce dont vous avez besoin</span><span class="lang-th">ทุกสิ่งที่คุณต้องการ</span>
        </span>
      </div>
      <h2 class="reveal reveal-d1 font-display font-semibold text-cream leading-tight" style="font-size: clamp(2rem, 4.5vw, 3.4rem);">
        <span class="lang-en">Built for Restaurants<br/><em class="text-amber-gradient not-italic">in Thailand</em></span>
        <span class="lang-fr">Conçu pour les restaurants<br/><em class="text-amber-gradient not-italic">en Thaïlande</em></span>
        <span class="lang-th">สร้างสำหรับร้านอาหาร<br/><em class="text-amber-gradient not-italic">ในประเทศไทย</em></span>
      </h2>
      <p class="reveal reveal-d2 text-cream-dim text-[1.02rem] max-w-md mx-auto">
        <span class="lang-en">Every tool your restaurant needs to attract guests directly — and keep all the revenue.</span>
        <span class="lang-fr">Tous les outils dont votre restaurant a besoin pour attirer des clients directement et garder tous les revenus.</span>
        <span class="lang-th">ทุกเครื่องมือที่ร้านอาหารของคุณต้องการเพื่อดึงดูดแขกโดยตรง และรักษารายได้ทั้งหมด</span>
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
